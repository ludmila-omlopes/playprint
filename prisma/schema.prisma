generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ExternalProvider {
  STEAM
  PLAYSTATION
  XBOX
  IGDB
  HLTB
  METACRITIC
}

enum UserGameStatus {
  OWNED
  WISHLIST
  PLAYING
  BACKLOG
  COMPLETED
}

enum EntrySource {
  STEAM
  PLAYSTATION
  XBOX
  CSV
  MANUAL
}

enum ImportJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ImportRowStatus {
  IMPORTED
  SKIPPED
  FAILED
}

enum BacklogFriction {
  CHOICE_OVERLOAD
  TIME_COMMITMENT
  GENRE_FATIGUE
  LOW_CONFIDENCE_MATCH
  TOO_MANY_SIMILAR_GAMES
  STALE_SESSION
  COMPLETION_PRESSURE
  TECHNICAL_OR_PLATFORM_FRICTION
  UNKNOWN
}

enum AssistantSignalType {
  UNTOUCHED
  SAMPLED_DROPPED
  STALE_PLAYING
  FINISHABLE_SOON
  LIKELY_FINISHED
  WISHLIST_RISK
  BUY_RISK
  RETURN_CANDIDATE
  RELEASE_CANDIDATE
}

model User {
  id               String            @id @default(cuid())
  displayName      String?
  avatarUrl        String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  externalAccounts ExternalAccount[]
  gameEntries      UserGameEntry[]
  importJobs       ImportJob[]
  gameInsights     UserGameInsight[]
  assistantRuns    AssistantRun[]
  playerProfile    PlayerProfile?
}

model ExternalAccount {
  id                String           @id @default(cuid())
  userId            String
  provider          ExternalProvider
  providerAccountId String
  username          String?
  displayName       String?
  avatarUrl         String?
  profileUrl        String?
  metadata          Json?
  lastSyncedAt      DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameEntries       UserGameEntry[]

  @@unique([provider, providerAccountId])
  @@index([userId, provider])
}

model Game {
  id                       String             @id @default(cuid())
  slug                     String             @unique
  name                     String
  normalizedName           String
  summary                  String?
  coverUrl                 String?
  heroUrl                  String?
  releaseDate              DateTime?
  aggregatedRating         Float?
  totalRatingCount         Int?
  genres                   Json?
  platforms                Json?
  screenshots              Json?
  websites                 Json?
  metadataSource           ExternalProvider?
  igdbId                   Int?               @unique
  igdbSlug                 String?
  hltbMainStoryMinutes     Int?
  hltbMainExtraMinutes     Int?
  hltbCompletionistMinutes Int?
  hltbUpdatedAt            DateTime?
  metacriticScore          Int?
  metacriticUrl            String?
  metacriticUpdatedAt      DateTime?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  providerLinks            GameProviderLink[]
  userEntries              UserGameEntry[]
  importRows               ImportRow[]

  @@index([normalizedName])
}

model GameProviderLink {
  id                        String           @id @default(cuid())
  gameId                    String
  provider                  ExternalProvider
  providerGameId            String
  storeUrl                  String?
  rawData                   Json?
  // Cached id/name of the achievement or trophy awarded when the main story
  // ends ("credits roll"). Source is "ai", "heuristic", or "none" when the
  // game has no detectable story-completion achievement.
  storyAchievementId        String?
  storyAchievementName      String?
  storyAchievementSource    String?
  storyAchievementCheckedAt DateTime?
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt
  game           Game             @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([provider, providerGameId])
  @@index([gameId])
}

model UserGameEntry {
  id                String            @id @default(cuid())
  userId            String
  gameId            String
  status            UserGameStatus
  source            EntrySource
  provider          ExternalProvider?
  externalAccountId String?
  platformName      String?
  playtimeMinutes   Int?
  lastPlayedAt      DateTime?
  // Achievement/trophy progress (0-100). This is NOT story completion; a game
  // is "finished" when finishedAt is set or status is COMPLETED.
  completionPercent Int?
  finishedAt        DateTime?
  // "manual" | "import" | "story_achievement" | "inferred"
  finishedSource    String?
  notes             String?
  isFavorite        Boolean           @default(false)
  startedAt         DateTime?
  abandonedAt       DateTime?
  abandonReason     String?
  activeBacklog     Boolean           @default(true)
  userIntent        String?
  desiredSessionMin Int?
  lastSyncedAt      DateTime?
  rawData           Json?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  game              Game              @relation(fields: [gameId], references: [id], onDelete: Cascade)
  externalAccount   ExternalAccount?  @relation(fields: [externalAccountId], references: [id], onDelete: SetNull)
  insights          UserGameInsight[]

  @@unique([userId, gameId, status])
  @@index([userId, status])
}

model UserGameInsight {
  id              String              @id @default(cuid())
  userId          String
  userGameEntryId String
  signalType      AssistantSignalType
  friction        BacklogFriction
  score           Int
  confidence      Int
  reasons         Json
  suggestedAction String?
  generatedBy     String              @default("rules")
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  userGameEntry   UserGameEntry       @relation(fields: [userGameEntryId], references: [id], onDelete: Cascade)

  @@unique([userGameEntryId, signalType])
  @@index([userId, signalType])
  @@index([userId, score])
}

model AssistantRun {
  id            String   @id @default(cuid())
  userId        String
  inputSummary  Json
  outputSummary Json
  model         String?
  status        String
  error         String?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model PlayerProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  summary   String
  profile   Json
  toolTrace Json?
  model     String?
  status    String
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ImportJob {
  id            String          @id @default(cuid())
  userId        String
  fileName      String
  status        ImportJobStatus @default(PENDING)
  columnMapping Json?
  summary       Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  completedAt   DateTime?
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  rows          ImportRow[]

  @@index([userId, createdAt])
}

model ImportRow {
  id                String           @id @default(cuid())
  jobId             String
  rowIndex          Int
  rawData           Json
  normalizedTitle   String?
  platformName      String?
  statusText        String?
  playtimeMinutes   Int?
  completionPercent Int?
  notes             String?
  externalId        String?
  outcome           ImportRowStatus?
  error             String?
  matchedGameId     String?
  createdAt         DateTime         @default(now())
  job               ImportJob        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  matchedGame       Game?            @relation(fields: [matchedGameId], references: [id], onDelete: SetNull)

  @@index([jobId, rowIndex])
}
